<odoo>

    <!-- CLIENT ACTION -->
    <record id="action_marketplace_dashboard" model="ir.actions.client">
        <field name="name">Marketplace Dashboard</field>
        <field name="tag">marketplace_dashboard.dashboard</field>
    </record>

    <!-- ROOT MENU -->
    <menuitem id="menu_marketplace_dashboard_root"
              name="Marketplace"
              sequence="10"
              web_icon="marketplace_dashboard,static/description/icon.png"/>

    <!-- DASHBOARD MENU -->
    <menuitem id="menu_marketplace_dashboard"
              name="Dashboard"
              parent="menu_marketplace_dashboard_root"
              action="action_marketplace_dashboard"
              sequence="1"/>

</odoo>